# ===== FinMind API =====
FINMIND_USER=your_finmind_user_id
FINMIND_PASSWORD=your_finmind_password

# ===== Ollama Cloud API =====
OLLAMA_API_KEY=your_ollama_api_key

# ===== PostgreSQL / Supabase 資料庫 =====
# DB_TYPE 可選: sqlite, postgres, supabase
DB_TYPE=sqlite
DB_NAME=stock_database
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# 若 DB_TYPE 設為 supabase，可直接設定下方的連線字串 (優先度最高)
# 格式例如: postgresql://postgres:[您的密碼]@db.[您的專案ID].supabase.co:5432/postgres?sslmode=require
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres?sslmode=require

# ===== 資料檔案路徑 =====
COMPANY_PARQUET_PATH=/path/to/company_baseinfo.parquet
